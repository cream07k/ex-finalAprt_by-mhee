# ═══════════════════════════════════════════════════════════
#  APT Utility — environment variables
#  Copy เป็น .env.local แล้วแก้ค่าก่อนใช้งาน
# ═══════════════════════════════════════════════════════════

# ── Authentication ──
ADMIN_PASSWORD=                # รหัสผ่าน admin (ตั้งให้ยาก ≥ 12 ตัว)
JWT_SECRET=                    # สร้างด้วย: openssl rand -hex 32

# ── Database (Postgres) ──
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# ── EasySlip API ──
SLIP_API_KEY=                  # https://easyslip.com

# ── App URL ──
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ── Production ──
NODE_ENV=production
